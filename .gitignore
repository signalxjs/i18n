# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
docs/dist/
*.d.ts
*.d.ts.map
!packages/runtime-core/src/jsx-types.d.ts
# Hand-authored source .d.ts (ambient decls) live under src/ and must be tracked
# — only built .d.ts under dist/ are outputs.
!packages/i18n/src/**/*.d.ts
# Ambient declarations for the Vite virtual modules — shipped as-is (it is a
# published entry, `@sigx/i18n/virtual`), so it lives at the package root
# rather than in src/, where nothing would emit it into dist/.
!packages/i18n/virtual.d.ts
# Hand-authored ambient declarations in the examples (virtual modules an app
# must declare). Generated ones — `i18n.gen.d.ts` — stay ignored.
!examples/*/src/env.d.ts
*.js
*.js.map

# Keep specific JS files
!vite.config.js
!*.config.js
!examples/*.js
!scripts/*.js

# TypeScript cache
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing
coverage/

# Misc
.cache/
.temp/
.tmp/

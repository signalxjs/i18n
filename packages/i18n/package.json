{
    "name": "@sigx/i18n",
    "version": "0.1.0",
    "description": "Reactive localization (i18n) for SignalX - namespaces, master fallback, typed keys, SSR",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js"
        },
        "./vite": {
            "types": "./dist/vite.d.ts",
            "import": "./dist/vite.js"
        }
    },
    "bin": {
        "sigx-i18n": "bin/sigx-i18n.mjs"
    },
    "files": [
        "dist",
        "bin"
    ],
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch"
    },
    "keywords": [
        "sigx",
        "i18n",
        "l10n",
        "localization",
        "internationalization",
        "translation",
        "reactive",
        "ssr"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/i18n.git",
        "directory": "packages/i18n"
    },
    "homepage": "https://sigx.dev/i18n/",
    "bugs": {
        "url": "https://github.com/signalxjs/i18n/issues"
    },
    "peerDependencies": {
        "@sigx/reactivity": ">=0.10.0 <0.11.0",
        "@sigx/runtime-core": ">=0.10.0 <0.11.0",
        "@sigx/store": ">=0.8.0 <0.9.0",
        "@sigx/vite": ">=0.10.0 <0.11.0",
        "sigx": ">=0.10.0 <0.11.0",
        "vite": "^8.0.0"
    },
    "peerDependenciesMeta": {
        "@sigx/vite": {
            "optional": true
        },
        "sigx": {
            "optional": true
        },
        "vite": {
            "optional": true
        }
    },
    "devDependencies": {
        "@sigx/reactivity": "^0.10.0",
        "@sigx/runtime-core": "^0.10.0",
        "@sigx/store": "^0.8.0",
        "@sigx/vite": "^0.10.0",
        "@types/node": "^25.9.1",
        "sigx": "^0.10.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.3"
    },
    "publishConfig": {
        "access": "public"
    }
}

{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "sigx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@sigx/i18n": ["./packages/i18n/src/index.ts"],
      "@sigx/i18n/server": ["./packages/i18n/src/server.ts"],
      "@sigx/i18n/server/node": ["./packages/i18n/src/server-node.ts"],
      "@sigx/i18n/vite": ["./packages/i18n/src/vite.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "packages/*/dist"
  ]
}
